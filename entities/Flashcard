{
  "name": "Flashcard",
  "type": "object",
  "properties": {
    "set_id": {
      "type": "string"
    },
    "front": {
      "type": "string"
    },
    "back": {
      "type": "string"
    },
    "front_image": {
      "type": "string",
      "description": "URL of image on front side"
    },
    "back_image": {
      "type": "string",
      "description": "URL of image on back side"
    },
    "card_type": {
      "type": "string",
      "enum": [
        "standard",
        "cloze"
      ],
      "default": "standard",
      "description": "standard = flip card, cloze = fill in the blank"
    },
    "order": {
      "type": "number",
      "default": 0
    },
    "ease_factor": {
      "type": "number",
      "default": 2.5,
      "description": "Spaced repetition ease factor"
    },
    "interval": {
      "type": "number",
      "default": 1,
      "description": "Days until next review"
    },
    "due_date": {
      "type": "string",
      "description": "Next review due date"
    },
    "times_correct": {
      "type": "number",
      "default": 0
    },
    "times_incorrect": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "set_id",
    "front",
    "back"
  ]
}